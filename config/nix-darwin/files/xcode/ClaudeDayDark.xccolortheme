		<string>0.6588 0.6471 0.6235 1</string>
		<key>xcode.syntax.declaration.other</key>
		<string>0.5765 0.7098 0.8784 1</string>
		<key>xcode.syntax.declaration.type</key>
		<string>0.4902 0.6471 0.8471 1</string>
