	<key>DVTConsoleExectuableOutputTextFont</key>
	<string>JetBrainsMonoNF-Regular - 14.0</string>
	<key>DVTConsoleTextBackgroundColor</key>
	<string>0.0745 0.0745 0.0706 1</string>
	<key>DVTConsoleTextInsertionPointColor</key>
	<string>0.8510 0.4667 0.3412 1</string>
	<key>DVTConsoleTextSelectionColor</key>
	<string>0.2902 0.2745 0.2392 1</string>
	<key>DVTFontAndColorVersion</key>
	<integer>1</integer>
	<key>DVTLineSpacing</key>
	<real>1.1</real>
	<key>DVTMarkupTextBackgroundColor</key>
	<string>0.1137 0.1098 0.1020 1</string>
