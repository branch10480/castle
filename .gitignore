config/anyenv/**
config/gh/
config/raycast/extensions/
config/karabiner/automatic_backups/
# opencode skills (wiki/jira)
config/opencode/skills/jira-get/
config/opencode/skills/jira-issue-create/
config/opencode/skills/jira-issue-update/
config/opencode/skills/project-item-link-issue/
config/opencode/skills/ap5/
config/opencode/skills/wiki-to-jira-create/
config/opencode/skills/wiki-to-jira-update/
# python cache
**/__pycache__/
*.pyc
**/.DS_Store
**/.serena

# Machine-local SSH commit signing roster (per-machine email/key pairs;
# not shared because work / personal Macs use different identities).
config/git/allowed_signers

# 1Password CLI runtime state (op-daemon.sock, plugins.sh, config.json...)
# are machine-local. Track only env-file templates that contain `op://`
# URI references — never raw secrets. The `[!.]*.env` form (rather than
# `*.env`) excludes dotfile env-files like `.cache.env` to keep any
# future runtime state under a hidden name from being unintentionally
# allowlisted.
config/op/*
!config/op/[!.]*.env

# Claude Code が `Agent({isolation: "worktree"})` 等で生成する一時 worktree
# ディレクトリ。中身は別ブランチの作業コピーで machine-local かつ短命な
# ため、castle 側では追跡しない。
.claude/worktrees/

# Ghostty の machine-local override (hammerspoon/init.lua が OS appearance
# に応じて font-size を書き換える動的ファイル)。本体 config からは
# `config-file = ?config.local` で optional include され、ファイルが
# 無い環境でも壊れない。詳細はテーマ運用ルール (CLAUDE.md) 参照。
config/ghostty/config.local

# Hammerspoon の machine-local OFF スイッチ。
# hammerspoon/init.lua は ~/.hammerspoon/appearance-auto.disabled が存在
# するとき時刻ベース appearance 自動切替を無効化する。~/.hammerspoon は
# homeshick の symlink 越しに castle/hammerspoon/ を指すため、flag を
# 作るとここに着地する。machine ごとの一時 OFF 状態なので追跡しない。
hammerspoon/*.disabled
