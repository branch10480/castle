# Auto update
auto-update-channel = tip

# Font settings.
# JetBrainsMono Nerd Font Mono を 1 番手にすることでターミナル列の整列が崩れない
# （Mono バリアントは Nerd Font glyph を強制等幅化）。castle 全体で
# "コードフォント = NFM" の方針に揃える（design-system.html / Xcode と同じ）。
# fallback として無印 NF も残し、未導入環境でも破綻しない。
#font-family = FiraCode Nerd Font
font-family = JetBrainsMono Nerd Font Mono
font-family = JetBrainsMono Nerd Font
font-family = Hiragino Sans W3
font-style = Light
font-size = 14

# Force JP code points to Hiragino Sans (gothic) so CJK fallback is explicit
font-codepoint-map = U+3000-U+303F=Hiragino Sans W3
font-codepoint-map = U+3040-U+309F=Hiragino Sans W3
font-codepoint-map = U+30A0-U+30FF=Hiragino Sans W3
font-codepoint-map = U+3400-U+4DBF=Hiragino Sans W3
font-codepoint-map = U+4E00-U+9FFF=Hiragino Sans W3
font-codepoint-map = U+FF00-U+FFEF=Hiragino Sans W3

# Theme
# theme = light:Belafonte Day,dark:Kanagawa Dragon
# theme = light:Alabaster,dark:Kanagawa Dragon
# theme = light:3024 Day Custom,dark:Solarized Dark Patched
# theme = light:Claude Day,dark:Kanagawa Dragon
# theme = Claude Day
# theme = Solarized Dark Patched
# theme = 0x96f
# theme = Kanagawa Dragon
# Both light/dark stay in castle's Claude Day vocabulary now (was: dark side
# was Kanagawa Dragon — replaced by Claude Day Dark for design-language
# consistency with htmla / markdownobserver / Xcode).
theme = light:Claude Day,dark:Claude Day Dark

# Window appearance
unfocused-split-opacity = 1
background-opacity = 1.0
#background-blur-radius = 5
macos-titlebar-style = tabs
split-divider-color = #54546d

# Window size
window-width = 122
window-height = 38

# Cursor
#cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor,sudo,title

# Keybindings - Send ESC (0x1B) for Ctrl+[ instead of fixterms CSI 91;5u
keybind = ctrl+left_bracket=text:\x1b

# ─────────────────────────────────────────────────────────────
# Force CSI u (fixterms) for Ctrl+Shift+<letter>
# ─────────────────────────────────────────────────────────────
# Ghostty は ASCII にマップ可能なキー (Ctrl+Shift+h など) について、
# 古い経路 (`^H` = 0x08) を優先送信し Shift 修飾を落としてしまう。
# tmux 側の `bind -n C-S-h resize-pane -L <N>` 等を発火させるには、
# Ghostty が CSI u 拡張シーケンスで明示的に送る必要がある（実際の <N> は
# home/.tmux.conf 参照、ここでは Shift 修飾を tmux に届ける配管が論点）。
# Modifier 値: 1 + Shift(1) + Alt(2) + Ctrl(4) = Ctrl+Shift は 6
# ASCII 値: h=104, j=106, k=107, l=108, ==61
keybind = ctrl+shift+h=csi:104;6u
keybind = ctrl+shift+j=csi:106;6u
keybind = ctrl+shift+k=csi:107;6u
keybind = ctrl+shift+l=csi:108;6u
keybind = ctrl+shift+equal=csi:61;6u

# ─────────────────────────────────────────────────────────────
# HHKB: Ctrl+b/f/p/n を矢印キーに翻訳（emacs/readline 互換）
# ─────────────────────────────────────────────────────────────
# Claude Code (Ink TextInput) は readline スタイルの cursor 移動を
# サポートしておらず、~/.claude/keybindings.json でも cursor:* に相当する
# action が公開されていない。HHKB は矢印が Fn+[;'/.] の 2 キー入力で
# ホームポジションから遠いので、Ghostty 層で C-b/f/p/n を矢印エスケープに
# 書き換えて下流（tmux → shell → Claude Code 等）に流す。
#
# 副作用の許容範囲:
# - zsh emacs モード: C-b/f/p/n と矢印は等価バインドなので挙動不変
# - vim/nvim: ユーザは hjkl のみ使用するため C-b/f (ページスクロール) /
#   C-p/n (insert 補完) を失っても無痛
# - less / tmux copy-mode-vi: C-b/f のページ移動が 1 行スクロールに劣化
keybind = ctrl+b=csi:D
keybind = ctrl+f=csi:C
keybind = ctrl+p=csi:A
keybind = ctrl+n=csi:B

