<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Claude Day (Light) — Xcode color theme.

  Hybrid design: editor *chrome* (background, cursor, selection, current line,
  scrollbar markers, console, markup) follows castle's Claude Day palette
  (claude/skills/htmla/design-system.html). Source-text *syntax colors*
  adopt Xcode's stock Sunset palette — its warm-ish base (orange comment,
  terracotta type, deep-blue keyword) sits naturally on Claude Day's ivory
  background and avoids the all-warm-on-all-warm readability trap that a pure
  Claude Day syntax has.

  Token reference (RGBA float):
    ivory   #FAF9F5  0.9804 0.9765 0.9608 1   page background
    paper   #FFFFFF  1.0000 1.0000 1.0000 1   panels
    slate   #141413  0.0784 0.0784 0.0745 1   text · plain identifiers
    clay    #D97757  0.8510 0.4667 0.3412 1   accent · cursor · macro / preprocessor / attribute
    clay-d  #B85C3E  0.7216 0.3608 0.2431 1   keyword · type · class · link · markup strong
    oat     #E3DACC  0.8902 0.8549 0.8000 1   selection
    olive   #788C5D  0.4706 0.5490 0.3647 1   secondary accent
    olive-d #5C6E45  0.3608 0.4314 0.2706 1   string · function · doc-keyword · stdout
    mustard #C78E3F  0.7804 0.5569 0.2471 1   number · constant · warning
    ruby    #B04A3F  0.6902 0.2902 0.2471 1   regex · error · diff conflict
    g100    #F0EEE6  0.9412 0.9333 0.9020 1   current-line highlight · markup bg
    g200    #E6E3DA  0.9020 0.8902 0.8549 1   hairline
    g300    #D1CFC5  0.8196 0.8118 0.7725 1   invisibles · markup border
    g500    #87867F  0.5294 0.5255 0.4980 1   comment · mark · diff
    g700    #3D3D3A  0.2392 0.2392 0.2275 1   debugger output · markup inline code · other heading

  Font: JetBrainsMonoNF-Regular - 11.5 (踏襲: 既存の My Classic (Light) と同じ。
  htmla 側は Mono バリアント (NFM) を採用しているが、Xcode は既存設定との
  メトリクス互換性を優先して NF のまま揃える。
  Console (debug area) は Light/Dark 共通ルールとして Source Editor から
  -1pt = 10.5pt に設定。本文との情報密度の違いを縮尺で出すための意図的な
  ずらし (詳細は下の Console セクションのコメント参照)。

  Line spacing: DVTLineSpacing = 1.0 (tight)。Xcode はこの key を
  line-height multiplier として解釈し、内蔵 Default は 1.1 相当だが、
  castle では Light/Dark 共通で 1.0 に詰めて 1 画面あたりの行数を稼ぐ
  方針 (1.0 = フォントメトリクスそのまま、追加 line gap 0)。
-->
<plist version="1.0">
<dict>
	<!--
	  Console (debug area) — designed to match the source editor "本文" feel.
	  Background, cursor, selection use the same Claude Day chrome as the
	  source editor. Output text inherits the markup palette (slate / g700 /
	  olive-d / clay-d) so prose-style logs read like the rest of the theme,
	  not like a third-party widget. Font size は Source Editor から -1pt
	  (Light: 11.5pt → 10.5pt / Dark: 12.5pt → 11.5pt) — コンソールは大量のログを
	  一望する surface なので、本文よりやや細かいピッチで「これはソースでは
	  なくログ」という情報密度の違いを縮尺で示し、視点が source ↔ console を
	  ジャンプしても階層が崩れないようにする (旧版では source と同 pt に
	  揃えていたが、視覚的に source と log が混ざって見える副作用があり、
	  逆方向の "意図的に分離" へ方針転換した)。

	    DebuggerInput        slate    (#141413)  user input at (lldb) prompt
	    DebuggerOutput       g700     (#3D3D3A)  LLDB chatter (secondary tier)
	    DebuggerPrompt       clay-d   (#B85C3E)  the "(lldb)" accent itself
	    ExectuableInput      slate    (#141413)  stdin from interactive runs
	    ExectuableOutput     slate    (#141413)  stdout — primary tier, same as
	                                             body text. Earlier olive-d
	                                             (#5C6E45) was too low-contrast
	                                             on ivory for long log reading;
	                                             slate keeps stdout as readable
	                                             as the source editor body.
	                                             LLDB chatter stays one tier
	                                             down at g700 so the hierarchy
	                                             "app log > debugger noise" is
	                                             still expressed via lightness.
	    TextBackground       ivory    (#FAF9F5)  same ground as source editor
	    TextInsertionPoint   clay     (#D97757)  cursor accent
	    TextSelection        oat      (#E3DACC)  warm-neutral selection

	  Note: Apple's key naming "Exectuable" is a typo in Xcode itself
	  (Executable → Exectuable). Do NOT correct it; Xcode reads exactly
	  this misspelling.
	-->
	<key>DVTConsoleDebuggerInputTextColor</key>
	<string>0.0784 0.0784 0.0745 1</string>
	<key>DVTConsoleDebuggerInputTextFont</key>
	<string>JetBrainsMonoNF-Regular - 10.5</string>
	<key>DVTConsoleDebuggerOutputTextColor</key>
	<string>0.2392 0.2392 0.2275 1</string>
	<key>DVTConsoleDebuggerOutputTextFont</key>
	<string>JetBrainsMonoNF-Regular - 10.5</string>
	<key>DVTConsoleDebuggerPromptTextColor</key>
	<string>0.7216 0.3608 0.2431 1</string>
	<key>DVTConsoleDebuggerPromptTextFont</key>
	<string>JetBrainsMonoNF-Regular - 10.5</string>
	<key>DVTConsoleExectuableInputTextColor</key>
	<string>0.0784 0.0784 0.0745 1</string>
	<key>DVTConsoleExectuableInputTextFont</key>
	<string>JetBrainsMonoNF-Regular - 10.5</string>
	<key>DVTConsoleExectuableOutputTextColor</key>
	<string>0.0784 0.0784 0.0745 1</string>
	<key>DVTConsoleExectuableOutputTextFont</key>
	<string>JetBrainsMonoNF-Regular - 10.5</string>
	<key>DVTConsoleTextBackgroundColor</key>
	<string>0.9804 0.9765 0.9608 1</string>
	<key>DVTConsoleTextInsertionPointColor</key>
	<string>0.8510 0.4667 0.3412 1</string>
	<key>DVTConsoleTextSelectionColor</key>
	<string>0.8902 0.8549 0.8000 1</string>
	<key>DVTFontAndColorVersion</key>
	<integer>1</integer>
	<key>DVTLineSpacing</key>
	<real>1.0</real>
	<key>DVTMarkupTextBackgroundColor</key>
	<string>0.9412 0.9333 0.9020 1</string>
	<key>DVTMarkupTextBorderColor</key>
	<string>0.8196 0.8118 0.7725 1</string>
	<key>DVTMarkupTextCodeFont</key>
	<string>JetBrainsMonoNF-Regular - 8.5</string>
