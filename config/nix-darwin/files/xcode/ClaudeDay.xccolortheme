	<string>0.8902 0.8549 0.8000 1</string>
	<key>DVTSourceTextSyntaxColors</key>
	<!--
	  Syntax colors adopt Xcode's Sunset palette as the base.
	  Sunset's signature traits, on top of Claude Day's ivory chrome:
	    - comment   = warm gray g500 (#87867F)  ← overridden from Sunset's
	                  loud orange to match castle's "muted text = g500" rule
	                  (markdownobserver's --reader-fg-secondary also uses g500)
	    - mark / comment.doc.keyword = warm gray g700 (#3D3D3A) ← comment-level
	                  "headings", one shade darker than comment body
	    - type/class = deep terracotta (#B44500)  ← almost identical to clay-d
	    - keyword + number = deep blue (#294277)  ← calm, low-fatigue
	    - identifier = dusty blue (#476A97)  ← own / system not differentiated
	    - macro / preprocessor = dusty purple (#646485)
	    - string    = vivid red (#DF0700)
	  Claude Day stays expressed via the editor *chrome* (background, cursor,
	  selection, scrollbar markers, console, markup) above and below this dict.
	  Regex tokens reuse Sunset hues (string-like = vivid red, identifier-like
	  = dusty blue, number-like = deep blue) since Sunset itself does not
	  define them. plain / regex.other use Claude Day's slate (#141413) instead
	  of Sunset's pure black to match markdownobserver's body text and keep
	  castle's "body = slate" rule consistent across surfaces.
	-->
	<dict>
		<key>xcode.syntax.attribute</key>
		<string>0.171 0.197 0.615 1</string>
		<key>xcode.syntax.character</key>
		<string>0.161 0.259 0.467 1</string>
		<key>xcode.syntax.comment</key>
		<string>0.5294 0.5255 0.4980 1</string>
		<key>xcode.syntax.comment.doc</key>
		<string>0.5294 0.5255 0.4980 1</string>
		<key>xcode.syntax.comment.doc.keyword</key>
		<string>0.2392 0.2392 0.2275 1</string>
		<key>xcode.syntax.declaration.other</key>
		<string>0.0588235 0.407843 0.627451 1</string>
		<key>xcode.syntax.declaration.type</key>
		<string>0.0431373 0.309804 0.47451 1</string>
		<key>xcode.syntax.identifier.class</key>
		<string>0.706 0.27 0 1</string>
		<key>xcode.syntax.identifier.class.system</key>
		<string>0.706 0.27 0 1</string>
		<key>xcode.syntax.identifier.constant</key>
		<string>0.278 0.415 0.593 1</string>
		<key>xcode.syntax.identifier.constant.system</key>
		<string>0.278 0.415 0.593 1</string>
		<key>xcode.syntax.identifier.function</key>
		<string>0.278 0.415 0.593 1</string>
		<key>xcode.syntax.identifier.function.system</key>
		<string>0.278 0.415 0.593 1</string>
		<key>xcode.syntax.identifier.macro</key>
		<string>0.392 0.391 0.52 1</string>
		<key>xcode.syntax.identifier.macro.system</key>
		<string>0.392 0.391 0.52 1</string>
		<key>xcode.syntax.identifier.type</key>
		<string>0.706 0.27 0 1</string>
		<key>xcode.syntax.identifier.type.system</key>
		<string>0.706 0.27 0 1</string>
		<key>xcode.syntax.identifier.variable</key>
		<string>0.278 0.415 0.593 1</string>
		<key>xcode.syntax.identifier.variable.system</key>
		<string>0.278 0.415 0.593 1</string>
		<key>xcode.syntax.keyword</key>
		<string>0.161 0.259 0.467 1</string>
		<key>xcode.syntax.mark</key>
		<string>0.2392 0.2392 0.2275 1</string>
		<key>xcode.syntax.markup.aside.kind</key>
		<string>0.607843 0.509161 0.568627 1</string>
		<key>xcode.syntax.markup.code</key>
		<string>0.665 0.052 0.569 1</string>
		<key>xcode.syntax.number</key>
		<string>0.161 0.259 0.467 1</string>
		<key>xcode.syntax.plain</key>
		<string>0.0784 0.0784 0.0745 1</string>
