	<string>0.2902 0.2745 0.2392 1</string>
	<key>DVTSourceTextSyntaxColors</key>
	<!--
	  Syntax colors = Light 版 (Sunset) を Dark 化したもの。
	  Light 版での「色と意味の対応」を維持しながら明度のみ反転している:

	    - comment            = warm gray g500 (#87867F)  ← Light と共通
	                           暗背景でも読める muted。Light 版で markdownobserver の
	                           reader-fg-secondary も同色だったので踏襲。
	    - comment.doc.keyword/ mark = g700-d (#a8a59f)   ← Dark での "明るい secondary"
	                           Light 版の "1 段濃い gray" を Dark では "1 段明るい gray" に
	                           対応させ、本文よりやや控えめなアクセントを残す。
	    - type/class         = link-d (#e08576)          ← Light の terracotta #B44500
	    - keyword + number   = blue-1 (#7da5d8)          ← Light の deep blue #294277
	    - identifier         = blue-2 (#93b5e0)          ← Light の dusty blue #476A97
	    - macro/preprocessor = lavender (#b0a0d0)        ← Light の dusty purple #646485
	    - string + regex     = ruby-d (#d97766)          ← Light の vivid red #DF0700
	    - markup.code / aside.kind = pink-d (#c4889d)    ← Light の magenta/dusty pink

	  plain / regex.other は Light と同じく「本文と同色」(Dark では fg-d #d4cfc1) を
	  使い、ターミナル / markdownobserver の本文色と揃える。
	-->
	<dict>
