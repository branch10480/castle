	<string>.AppleSystemUIFontBold - 8.5</string>
	<key>DVTScrollbarMarkerAnalyzerColor</key>
	<string>0.3608 0.4314 0.2706 1</string>
	<key>DVTScrollbarMarkerBreakpointColor</key>
	<string>0.8510 0.4667 0.3412 1</string>
	<key>DVTScrollbarMarkerDiffColor</key>
	<string>0.5294 0.5255 0.4980 1</string>
	<key>DVTScrollbarMarkerDiffConflictColor</key>
	<string>0.6902 0.2902 0.2471 1</string>
	<key>DVTScrollbarMarkerErrorColor</key>
	<string>0.6902 0.2902 0.2471 1</string>
	<key>DVTScrollbarMarkerRuntimeIssueColor</key>
	<string>0.7804 0.5569 0.2471 1</string>
	<key>DVTScrollbarMarkerWarningColor</key>
	<string>0.7804 0.5569 0.2471 1</string>
	<key>DVTSourceTextBackground</key>
	<string>0.9804 0.9765 0.9608 1</string>
	<key>DVTSourceTextBlockDimBackgroundColor</key>
	<string>0.0784 0.0784 0.0745 0.4</string>
	<key>DVTSourceTextCurrentLineHighlightColor</key>
	<string>0.9412 0.9333 0.9020 1</string>
