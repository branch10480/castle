# Auto update
auto-update-channel = tip

# Font settings (from WezTerm config)
#font-family = FiraCode Nerd Font
font-family = JetBrainsMono Nerd Font
font-family = Hiragino Sans W3
font-style = Light
font-size = 14

# Force JP code points to Hiragino Sans (gothic) so CJK fallback is explicit
font-codepoint-map = U+3000-U+303F=Hiragino Sans W3
font-codepoint-map = U+3040-U+309F=Hiragino Sans W3
font-codepoint-map = U+30A0-U+30FF=Hiragino Sans W3
font-codepoint-map = U+3400-U+4DBF=Hiragino Sans W3
font-codepoint-map = U+4E00-U+9FFF=Hiragino Sans W3
font-codepoint-map = U+FF00-U+FFEF=Hiragino Sans W3

# Theme
# theme = light:Belafonte Day,dark:Kanagawa Dragon
# theme = light:Alabaster,dark:Kanagawa Dragon
# theme = light:3024 Day Custom,dark:Solarized Dark Patched
# theme = Solarized Dark Patched
# theme = 0x96f
theme = Kanagawa Dragon

# Window appearance
#unfocused-split-opacity = 1
background-opacity = 0.75
background-blur-radius = 5
macos-titlebar-style = tabs

# Window size
window-width = 122
window-height = 38

# Cursor
#cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor,sudo,title

# Keybindings - Send ESC (0x1B) for Ctrl+[ instead of fixterms CSI 91;5u
keybind = ctrl+left_bracket=text:\x1b

# Keybindings - Pane split
keybind = ctrl+semicolon=new_split:right
keybind = ctrl+apostrophe=new_split:down

# Keybindings - Pane navigation (Vim-style)
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

# Keybindings - Pane resize (direct shortcuts)
keybind = ctrl+shift+h=resize_split:left,30
keybind = ctrl+shift+j=resize_split:down,30
keybind = ctrl+shift+k=resize_split:up,30
keybind = ctrl+shift+l=resize_split:right,30
keybind = ctrl+shift+equal=equalize_splits

# Keybindings - Copy mode (Key Tables)
keybind = ctrl+shift+x=activate_key_table:copy
keybind = copy/k=scroll_page_lines:-1
keybind = copy/j=scroll_page_lines:1
keybind = copy/u=scroll_page_fractional:-0.5
keybind = copy/d=scroll_page_fractional:0.5
keybind = copy/g=scroll_to_top
keybind = copy/shift+g=scroll_to_bottom
keybind = copy/n=navigate_search:next
keybind = copy/shift+n=navigate_search:previous
keybind = copy/y=copy_to_clipboard
keybind = copy/escape=deactivate_key_table
keybind = copy/q=deactivate_key_table
keybind = copy/catch_all=ignore

