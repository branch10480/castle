		<string>0.6588 0.6471 0.6235 1</string>
		<key>xcode.syntax.markup.aside.kind</key>
		<string>0.7686 0.5333 0.6157 1</string>
		<key>xcode.syntax.markup.code</key>
		<string>0.7686 0.5333 0.6157 1</string>
		<key>xcode.syntax.number</key>
